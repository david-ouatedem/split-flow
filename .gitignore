# Bundler
/.bundle
/vendor/bundle

# Environment files
/.env*
!/.env.example

# Logs and temp files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Storage (uploaded files in development)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# SQLite databases
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-wal

# Asset builds
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Credentials (keep encrypted, ignore keys)
/config/*.key
/config/credentials/*.key

# Node
/node_modules/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Docker
docker-compose.override.yml

# Claude Code
.claude/settings.local.json

# Spec document (not source code)
*.docx

# Coverage
/coverage/
