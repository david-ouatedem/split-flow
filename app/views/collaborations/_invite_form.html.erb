<%= form_with(url: project_collaborations_path(project), scope: :collaboration, class: "flex gap-2 items-end") do |f| %>
  <div class="form-control flex-1">
    <%= f.label :email, "Email", class: "label" %>
    <%= f.email_field :email, class: "input input-bordered w-full input-sm", placeholder: "collaborator@email.com", required: true %>
  </div>
  <div class="form-control w-40">
    <%= f.label :role, "Role", class: "label" %>
    <%= f.text_field :role, class: "input input-bordered w-full input-sm", placeholder: "e.g., Vocalist" %>
  </div>
  <%= f.submit "Invite", class: "btn btn-primary btn-sm" %>
<% end %>
