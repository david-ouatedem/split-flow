<div class="max-w-4xl mx-auto">
  <%# Project Details %>
  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="card-title text-3xl"><%= @project.title %></h1>
          <p class="text-sm text-base-content/70 mt-1">
            by <%= @project.owner.display_name || @project.owner.email %>
          </p>
        </div>
        <% if @project.owned_by?(current_user) %>
          <div class="flex gap-2">
            <%= link_to "Edit", edit_project_path(@project), class: "btn btn-outline btn-sm" %>
            <%= button_to "Delete", project_path(@project), method: :delete,
                data: { turbo_confirm: "Are you sure you want to delete this project?" },
                class: "btn btn-error btn-outline btn-sm" %>
          </div>
        <% end %>
      </div>

      <div class="flex flex-wrap gap-2 mt-3">
        <span class="badge badge-outline"><%= @project.visibility.gsub("_project", "").capitalize %></span>
        <span class="badge badge-<%= @project.active? ? 'success' : 'ghost' %>"><%= @project.status.capitalize %></span>
        <% if @project.genre.present? %>
          <span class="badge badge-secondary"><%= @project.genre %></span>
        <% end %>
        <% if @project.bpm.present? %>
          <span class="badge badge-ghost"><%= @project.bpm %> BPM</span>
        <% end %>
      </div>

      <% if @project.description.present? %>
        <p class="mt-4"><%= @project.description %></p>
      <% end %>
    </div>
  </div>

  <%# Collaborators %>
  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <h2 class="card-title">Collaborators</h2>

      <div id="collaborators-list">
        <% if @accepted_collaborations.any? %>
          <% @accepted_collaborations.each do |collaboration| %>
            <%= render partial: "collaborations/collaboration", locals: { collaboration: collaboration, project: @project } %>
          <% end %>
        <% else %>
          <p class="text-base-content/50 py-2">No collaborators yet.</p>
        <% end %>
      </div>

      <% if @project.owned_by?(current_user) %>
        <%# Pending invitations %>
        <% if @pending_collaborations&.any? %>
          <div class="divider">Pending Invitations</div>
          <% @pending_collaborations.each do |collaboration| %>
            <div class="flex items-center justify-between py-2" id="<%= dom_id(collaboration) %>">
              <div>
                <span class="font-medium"><%= collaboration.user.display_name || collaboration.user.email %></span>
                <% if collaboration.role.present? %>
                  <span class="badge badge-ghost badge-sm ml-1"><%= collaboration.role %></span>
                <% end %>
                <span class="badge badge-warning badge-sm ml-1">Pending</span>
                <% if collaboration.user.created_by_invite? && !collaboration.user.invitation_accepted? %>
                  <span class="badge badge-info badge-sm ml-1">Not yet registered</span>
                <% end %>
              </div>
              <%= button_to "Remove", project_collaboration_path(@project, collaboration), method: :delete, class: "btn btn-ghost btn-xs" %>
            </div>
          <% end %>
        <% end %>

        <%# Invite form %>
        <div class="divider">Invite Collaborator</div>
        <div id="invite_form">
          <%= render partial: "collaborations/invite_form", locals: { project: @project } %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Files Section %>
  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <h2 class="card-title">Files</h2>
        <% if @project_files.any? %>
          <%= link_to download_all_project_project_files_path(@project),
              class: "btn btn-outline btn-sm gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download All
          <% end %>
        <% end %>
      </div>

      <%# Upload Form %>
      <% if current_user %>
        <div class="collapse collapse-arrow bg-base-200 mb-4">
          <input type="checkbox" />
          <div class="collapse-title font-medium">
            Upload New File
          </div>
          <div class="collapse-content">
            <%= render partial: "project_files/upload_form",
                locals: { project: @project, project_file: @project.project_files.build } %>
          </div>
        </div>
      <% end %>

      <%# Files List %>
      <div id="project-files-list" class="space-y-3">
        <% if @project_files.any? %>
          <% @project_files.each do |project_file| %>
            <%= render partial: "project_files/file", locals: { project_file: project_file } %>
          <% end %>
        <% else %>
          <p class="text-base-content/50 py-4 text-center">No files uploaded yet.</p>
        <% end %>
      </div>
    </div>
  </div>

  <%# Split Agreement %>
  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <h2 class="card-title">Split Agreement</h2>
        <% if @split_agreement&.locked? %>
          <%= link_to export_pdf_project_split_agreement_path(@project), class: "btn btn-primary btn-sm gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Download PDF
          <% end %>
        <% end %>
      </div>
      <%= render partial: "split_agreements/agreement_card", locals: { project: @project, agreement: @split_agreement } %>
    </div>
  </div>
</div>
