<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <%= form_with(model: project, class: "space-y-4") do |f| %>
      <% if project.errors.any? %>
        <div class="alert alert-error">
          <ul>
            <% project.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-control">
        <%= f.label :title, class: "label" %>
        <%= f.text_field :title, class: "input input-bordered w-full", placeholder: "Track or session name" %>
      </div>

      <div class="form-control">
        <%= f.label :description, class: "label" %>
        <%= f.text_area :description, rows: 4, class: "textarea textarea-bordered w-full", placeholder: "Describe this project..." %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-control">
          <%= f.label :genre, class: "label" %>
          <%= f.text_field :genre, class: "input input-bordered w-full", placeholder: "e.g., Hip-Hop, R&B" %>
        </div>

        <div class="form-control">
          <%= f.label :bpm, "BPM", class: "label" %>
          <%= f.number_field :bpm, min: 1, max: 999, class: "input input-bordered w-full", placeholder: "e.g., 140" %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-control">
          <%= f.label :visibility, class: "label" %>
          <%= f.select :visibility, [["Private", "private_project"], ["Public", "public_project"]],
              {}, class: "select select-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :status, class: "label" %>
          <%= f.select :status, Project.statuses.keys.map { |s| [s.capitalize, s] },
              {}, class: "select select-bordered w-full" %>
        </div>
      </div>

      <div class="form-control mt-6">
        <%= f.submit class: "btn btn-primary w-full" %>
      </div>
    <% end %>
  </div>
</div>
