<div class="flex justify-center mt-10">
  <div class="card bg-base-100 shadow-xl w-full max-w-md">
    <div class="card-body">
      <h2 class="card-title text-2xl mb-2">Set Your Password</h2>
      <p class="text-base-content/70 mb-4">Welcome to SplitFlow! Set your password to accept the invitation and start collaborating.</p>

      <%= form_for resource, as: resource_name, url: invitation_path(resource_name), html: { method: :put, class: "space-y-4" } do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :invitation_token %>

        <div class="form-control">
          <%= f.label :display_name, class: "label" %>
          <%= f.text_field :display_name, autofocus: true, class: "input input-bordered w-full", placeholder: "Your display name" %>
        </div>

        <div class="form-control">
          <%= f.label :password, class: "label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "input input-bordered w-full" %>
          <% if @minimum_password_length %>
            <label class="label"><span class="label-text-alt"><%= @minimum_password_length %> characters minimum</span></label>
          <% end %>
        </div>

        <div class="form-control">
          <%= f.label :password_confirmation, class: "label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mt-6">
          <%= f.submit "Set Password & Join", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
