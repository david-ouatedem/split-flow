<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-6">
    <%= link_to project_split_agreement_path(@project), class: "btn btn-ghost btn-sm" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Agreement
    <% end %>
  </div>

  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h1 class="card-title text-3xl">Edit Split Agreement</h1>
          <p class="text-base-content/70 mt-2">
            Modify percentages before proposing to collaborators
          </p>
        </div>
        <span class="badge badge-warning badge-lg">Draft</span>
      </div>

      <%= render "form", agreement: @agreement, project: @project %>
    </div>
  </div>

  <div class="alert alert-warning mt-6">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
    </svg>
    <span>You can only edit this agreement while it's in draft status. Once proposed, modifications are locked.</span>
  </div>
</div>
