<div id="split-agreement-section">
  <% if agreement.nil? %>
    <%# No Agreement State %>
    <div class="text-center py-8">
      <p class="text-base-content/50 mb-4">No split agreement created yet.</p>
      <% if project.owned_by?(current_user) %>
        <p class="text-sm text-base-content/70 mb-6">
          As the project owner, you can propose how revenue should be split among collaborators.
        </p>
        <%= link_to "Create Split Agreement",
            new_project_split_agreement_path(project),
            class: "btn btn-primary" %>
      <% end %>
    </div>

  <% elsif agreement.draft? %>
    <%# Draft State %>
    <div class="space-y-4">
      <div class="alert alert-info">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>Draft agreement. Total must equal 100% before proposing.</span>
      </div>

      <%= render partial: "split_agreements/entries_table",
          locals: { agreement: agreement, entries: agreement.split_entries.includes(:user).order(:created_at) } %>

      <% if project.owned_by?(current_user) %>
        <div class="flex gap-2 justify-end">
          <%= link_to "Edit Percentages",
              edit_project_split_agreement_path(project),
              class: "btn btn-outline" %>

          <% if agreement.valid_percentages? %>
            <%= button_to "Propose Agreement",
                propose_project_split_agreement_path(project),
                method: :patch,
                class: "btn btn-primary",
                data: { turbo_confirm: "Propose this split agreement? All collaborators will need to approve." } %>
          <% else %>
            <button class="btn btn-disabled" disabled>
              Total must be 100% (currently <%= agreement.total_percentage.round(2) %>%)
            </button>
          <% end %>
        </div>
      <% end %>
    </div>

  <% elsif agreement.pending? %>
    <%# Pending State %>
    <div class="space-y-4">
      <div class="alert alert-warning">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <div class="font-semibold">Awaiting Approvals</div>
          <div class="text-sm">
            <%= agreement.split_entries.approved.count %> of <%= agreement.split_entries.count %> participants approved
          </div>
        </div>
      </div>

      <div class="space-y-2">
        <% agreement.split_entries.includes(:user).order(:created_at).each do |entry| %>
          <%= render partial: "split_entries/entry_row",
              locals: { entry: entry, project: project, agreement: agreement } %>
        <% end %>
      </div>
    </div>

  <% elsif agreement.locked? %>
    <%# Locked State %>
    <div class="space-y-4">
      <div class="alert alert-success">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <div class="font-semibold">Agreement Locked</div>
          <div class="text-sm">
            Finalized on <%= agreement.locked_at.strftime("%B %d, %Y at %I:%M %p") %>
          </div>
        </div>
      </div>

      <%= render partial: "split_agreements/entries_table",
          locals: { agreement: agreement, entries: agreement.split_entries.includes(:user).order(percentage: :desc) } %>

      <div class="divider">Verification</div>

      <div class="form-control">
        <label class="label">
          <span class="label-text font-semibold">Public Verification Link</span>
        </label>
        <div class="join w-full">
          <input type="text"
                 id="verification-url"
                 readonly
                 value="<%= verify_split_agreement_url(agreement.verification_token) %>"
                 class="input input-bordered join-item flex-1 text-sm" />
          <button class="btn btn-outline join-item"
                  data-controller="clipboard"
                  data-clipboard-target="button"
                  data-clipboard-text-value="<%= verify_split_agreement_url(agreement.verification_token) %>"
                  data-action="click->clipboard#copy">
            Copy Link
          </button>
        </div>
        <label class="label">
          <span class="label-text-alt">Anyone with this link can verify the agreement</span>
        </label>
      </div>
    </div>
  <% end %>
</div>
