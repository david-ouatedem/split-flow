<div id="<%= dom_id(project_file) %>" class="border border-base-300 rounded-lg p-4 hover:bg-base-200/50 transition">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="font-semibold truncate"><%= project_file.name %></h3>
        <span class="badge badge-outline badge-sm"><%= project_file.label %></span>
        <span class="badge badge-ghost badge-sm">v<%= project_file.version %></span>
      </div>

      <div class="text-sm text-base-content/70 space-y-1">
        <div>
          <span class="font-medium">Uploaded by:</span>
          <%= project_file.uploader.display_name || project_file.uploader.email %>
        </div>
        <div>
          <span class="font-medium">Size:</span>
          <%= number_to_human_size(project_file.file.byte_size) %>
          <span class="mx-2">•</span>
          <span class="font-medium">Uploaded:</span>
          <%= time_ago_in_words(project_file.created_at) %> ago
        </div>
      </div>

      <% if project_file.file.content_type&.start_with?("audio/") %>
        <div class="mt-3">
          <%= audio_tag rails_blob_url(project_file.file), controls: true, class: "w-full max-w-md" %>
        </div>
      <% end %>
    </div>

    <div class="flex flex-col gap-2">
      <%= link_to "Download", rails_blob_url(project_file.file, disposition: "attachment"),
          class: "btn btn-outline btn-sm",
          download: project_file.file.filename %>

      <% if current_user && (project_file.uploader == current_user || project_file.project.owned_by?(current_user)) %>
        <%= button_to "Delete",
            project_project_file_path(project_file.project, project_file),
            method: :delete,
            data: { turbo_confirm: "Are you sure you want to delete this file?" },
            class: "btn btn-error btn-outline btn-sm" %>
      <% end %>
    </div>
  </div>
</div>
