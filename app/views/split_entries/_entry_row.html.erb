<div id="<%= dom_id(entry) %>" class="card bg-base-200 border border-base-300">
  <div class="card-body py-4 px-6">
    <div class="flex items-center justify-between gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-1">
          <span class="font-semibold"><%= entry.user.display_name || entry.user.email.split('@').first %></span>
          <% if entry.user == project.owner %>
            <span class="badge badge-sm badge-primary">Owner</span>
          <% end %>
        </div>
        <div class="text-sm text-base-content/70"><%= entry.user.email %></div>
      </div>

      <div class="text-center">
        <div class="text-2xl font-bold"><%= number_with_precision(entry.percentage, precision: 2) %>%</div>
        <div class="text-xs text-base-content/60">Split Percentage</div>
      </div>

      <div class="text-right">
        <% if entry.approved? %>
          <div class="flex items-center gap-2 text-success">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
              <div class="font-semibold">Approved</div>
              <div class="text-xs text-base-content/60">
                <%= entry.approved_at.strftime("%b %d, %Y") %>
              </div>
            </div>
          </div>
        <% elsif current_user && entry.can_be_approved_by?(current_user) %>
          <%= button_to "Approve My Split",
              approve_project_split_agreement_split_entry_path(project, agreement, entry),
              method: :patch,
              class: "btn btn-success",
              data: { turbo_confirm: "Confirm your split percentage of #{number_with_precision(entry.percentage, precision: 2)}%?" } %>
        <% else %>
          <div class="badge badge-warning badge-lg">Awaiting Approval</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
