<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title><%= content_for(:title) || "SplitFlow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="SplitFlow">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-base-200">
    <div class="navbar bg-base-100 shadow-sm">
      <div class="flex-1">
        <%= link_to "SplitFlow", root_path, class: "btn btn-ghost text-xl" %>
      </div>
      <div class="flex-none gap-2">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", dashboard_path, class: "btn btn-ghost btn-sm" %>
          <%= link_to "Projects", projects_path, class: "btn btn-ghost btn-sm" %>
          <% pending_count = current_user.collaborations.pending.count %>
          <%= link_to invitations_path, class: "btn btn-ghost btn-sm" do %>
            Invitations
            <% if pending_count > 0 %>
              <span class="badge badge-sm badge-warning"><%= pending_count %></span>
            <% end %>
          <% end %>
          <%= link_to "Profile", profile_path, class: "btn btn-ghost btn-sm" %>
          <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn btn-ghost btn-sm" %>
        <% else %>
          <%= link_to "Log in", new_user_session_path, class: "btn btn-ghost btn-sm" %>
          <%= link_to "Sign up", new_user_registration_path, class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>

    <% if notice %>
      <div class="alert alert-success mx-auto mt-4 max-w-4xl" data-controller="flash">
        <span><%= notice %></span>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-error mx-auto mt-4 max-w-4xl" data-controller="flash">
        <span><%= alert %></span>
      </div>
    <% end %>

    <main class="container mx-auto mt-8 px-5">
      <%= yield %>
    </main>
  </body>
</html>
